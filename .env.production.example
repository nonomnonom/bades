# ====================================================================
# Bades Production Environment Variables
# ====================================================================
# Copy this file to .env and fill in the values for production deployment.
# All secrets should be managed via environment variables, not in this file.
# ====================================================================

# --------------------------------------------------------------------
# Image & Tag
# --------------------------------------------------------------------
TAG=latest
BADES_IMAGE=ghcr.io/nonomnonom/bades

# --------------------------------------------------------------------
# Mode Production
# --------------------------------------------------------------------
IS_MULTIWORKSPACE_ENABLED=true
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=false

# --------------------------------------------------------------------
# URL & Port
# --------------------------------------------------------------------
SERVER_URL=https://api.yourdomain.com
SERVER_PORT=3000

# --------------------------------------------------------------------
# Database (PostgreSQL)
# --------------------------------------------------------------------
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=YOUR_STRONG_PASSWORD_HERE
PG_DATABASE_HOST=your-db-host.com
PG_DATABASE_PORT=5432
PG_DATABASE_NAME=default

# --------------------------------------------------------------------
# Redis
# --------------------------------------------------------------------
REDIS_PASSWORD=YOUR_STRONG_REDIS_PASSWORD_HERE
REDIS_URL=redis://:YOUR_STRONG_REDIS_PASSWORD_HERE@your-redis-host.com:6379

# --------------------------------------------------------------------
# Secret Keys (generate with: openssl rand -base64 32)
# --------------------------------------------------------------------
ENCRYPTION_KEY=YOUR_32_CHAR_ENCRYPTION_KEY_HERE
FALLBACK_ENCRYPTION_KEY=YOUR_32_CHAR_FALLBACK_KEY_HERE
APP_SECRET=YOUR_APP_SECRET_HERE

# --------------------------------------------------------------------
# Storage (S3)
# --------------------------------------------------------------------
STORAGE_TYPE=s3
STORAGE_S3_REGION=ap-southeast-1
STORAGE_S3_NAME=your-bucket-name
STORAGE_S3_ENDPOINT=
STORAGE_S3_ACCESS_KEY_ID=
STORAGE_S3_SECRET_ACCESS_KEY=

# --------------------------------------------------------------------
# AI (OpenRouter)
# --------------------------------------------------------------------
OPENROUTER_API_KEY=sk-or-v1-...
AI_MODEL_PREFERENCES={"disabledModels":[],"recommendedModels":["openrouter/deepseek/deepseek-v4-flash"],"defaultFastModels":["openrouter/deepseek/deepseek-v4-flash"],"defaultSmartModels":["openrouter/deepseek/deepseek-v4-flash"]}

# --------------------------------------------------------------------
# Frontend
# --------------------------------------------------------------------
FRONTEND_URL=https://app.yourdomain.com
DEFAULT_SUBDOMAIN=app

# --------------------------------------------------------------------
# Logging & Monitoring
# --------------------------------------------------------------------
NODE_ENV=production
LOGGER_DRIVER=CONSOLE
EXCEPTION_HANDLER_DRIVER=sentry
SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_ENVIRONMENT=production
METER_DRIVER=Prometheus
OTLP_COLLECTOR_METRICS_ENDPOINT_URL=http://your-otel-collector:4318/v1/metrics
OTLP_COLLECTOR_TRACES_ENDPOINT_URL=http://your-otel-collector:4318/v1/traces

# --------------------------------------------------------------------
# Billing (Optional)
# --------------------------------------------------------------------
# IS_BILLING_ENABLED=true
# MIDTRANS_SERVER_KEY=
# MIDTRANS_CLIENT_KEY=
# MIDTRANS_IS_PRODUCTION=false

# --------------------------------------------------------------------
# Auth Providers (Optional)
# --------------------------------------------------------------------
# AUTH_GOOGLE_ENABLED=true
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_GOOGLE_CALLBACK_URL=https://api.yourdomain.com/auth/google/callback
