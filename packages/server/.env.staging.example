# Bades server — environment variables STAGING
#
# Checklist untuk task definition ECS Fargate Bades staging (cluster
# bades-cluster, service bades-staging-service) di region ap-southeast-3
# (Jakarta).
#
# Variabel sensitif (APP_SECRET, PG_DATABASE_URL, REDIS_URL, MIDTRANS_*,
# OPENROUTER_API_KEY) di-resolve dari AWS Secrets Manager prefix
# `bades/staging/<KEY>` — lihat `.github/DEPLOY.md` Step 4. Template task
# definition: `scripts/aws/bades-staging-task.json`.
#
# Staging boleh memakai sandbox Midtrans dan provider AI murah/dev.

# ───────────────────── Core runtime ─────────────────────
NODE_ENV=production
NODE_PORT=3000

APP_SECRET=replace_with_openssl_rand_hex_32

SERVER_URL=https://staging.bades.id
FRONTEND_URL=https://staging.bades.id

# ───────────────────── Database & cache ─────────────────────
PG_DATABASE_URL=postgres://bades:STRONG_PASSWORD@bades-staging.xxxxxx.ap-southeast-3.rds.amazonaws.com:5432/bades_staging
PG_SSL_ALLOW_SELF_SIGNED=true

REDIS_URL=redis://bades-staging.xxxxxx.cache.amazonaws.com:6379

# ───────────────────── Workspace / subdomain ─────────────────────
IS_MULTIWORKSPACE_ENABLED=true
DEFAULT_SUBDOMAIN=app
FRONT_AUTH_CALLBACK_URL=https://staging.bades.id/auth/verify
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=false
SIGN_IN_PREFILLED=false

# ───────────────────── Billing (Midtrans sandbox) ─────────────────────
IS_BILLING_ENABLED=true
IS_BILLING_MIDTRANS_ENABLED=true
MIDTRANS_SERVER_KEY=SB-Mid-server-REPLACE_WITH_SANDBOX_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-REPLACE_WITH_SANDBOX_KEY
MIDTRANS_IS_PRODUCTION=false
BILLING_PLAN_REQUIRED_LINK=https://staging.bades.id/pricing

# ───────────────────── Storage (S3 bucket terpisah, atau local untuk smoke test) ─────────────────────
STORAGE_TYPE=s3
STORAGE_S3_REGION=ap-southeast-3
STORAGE_S3_NAME=bades-staging-assets

# ───────────────────── Email (SES sandbox / SMTP test) ─────────────────────
EMAIL_DRIVER=smtp
EMAIL_FROM_ADDRESS=no-reply-staging@bades.id
EMAIL_FROM_NAME=Bades Staging
EMAIL_SMTP_HOST=email-smtp.ap-southeast-3.amazonaws.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=REPLACE_WITH_SES_SMTP_USER
EMAIL_SMTP_PASSWORD=REPLACE_WITH_SES_SMTP_PASSWORD
IS_EMAIL_VERIFICATION_REQUIRED=false

# ───────────────────── AI (single-model, OpenRouter dev key) ─────────────────────
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_DEV_KEY

# ───────────────────── Monitoring ─────────────────────
EXCEPTION_HANDLER_DRIVER=sentry
SENTRY_DSN=https://REPLACE@sentry.io/REPLACE
SENTRY_FRONT_DSN=https://REPLACE@sentry.io/REPLACE
SENTRY_ENVIRONMENT=staging
LOGGER_DRIVER=CONSOLE
LOG_LEVELS=error,warn,log
APPLICATION_LOG_DRIVER=CONSOLE

# ───────────────────── Rate limiting & security ─────────────────────
API_RATE_LIMITING_TTL=60
API_RATE_LIMITING_LIMIT=300
MUTATION_MAXIMUM_AFFECTED_RECORDS=100
HTTP_TOOL_SAFE_MODE_ENABLED=true
