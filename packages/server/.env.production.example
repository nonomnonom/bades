# Bades server — environment variables PRODUCTION
#
# Salin nilainya ke App Runner service `bades` (Configuration → Edit).
# Jangan commit file ini setelah diisi nilai asli — biarkan tetap example.

# ───────────────────── Core runtime ─────────────────────
NODE_ENV=production
NODE_PORT=3000

# Random string panjang, generate dengan: openssl rand -hex 32
APP_SECRET=replace_with_openssl_rand_hex_32

# URL publik service (custom domain App Runner di Cloudflare)
SERVER_URL=https://app.bades.id
FRONTEND_URL=https://app.bades.id

# ───────────────────── Database & cache ─────────────────────
# RDS PostgreSQL (gunakan SSL di production)
PG_DATABASE_URL=postgres://bades:STRONG_PASSWORD@bades-prod.xxxxxx.ap-southeast-1.rds.amazonaws.com:5432/bades
PG_SSL_ALLOW_SELF_SIGNED=false

# ElastiCache Redis
REDIS_URL=redis://bades-prod.xxxxxx.cache.amazonaws.com:6379

# ───────────────────── Workspace / subdomain ─────────────────────
# Multi-tenant: tiap desa punya subdomain sendiri (mis. sukamaju.bades.id)
IS_MULTIWORKSPACE_ENABLED=true
DEFAULT_SUBDOMAIN=app
FRONT_AUTH_CALLBACK_URL=https://app.bades.id/auth/verify
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=true

# ───────────────────── Billing (Midtrans, gateway utama Bades) ─────────────────────
IS_BILLING_ENABLED=true
IS_BILLING_MIDTRANS_ENABLED=true
MIDTRANS_SERVER_KEY=Mid-server-REPLACE_WITH_PRODUCTION_KEY
MIDTRANS_CLIENT_KEY=Mid-client-REPLACE_WITH_PRODUCTION_KEY
MIDTRANS_IS_PRODUCTION=true
BILLING_PLAN_REQUIRED_LINK=https://bades.id/pricing

# ───────────────────── Storage (S3 untuk produksi) ─────────────────────
STORAGE_TYPE=s3
STORAGE_S3_REGION=ap-southeast-1
STORAGE_S3_NAME=bades-prod-assets
# Opsional jika pakai access key terpisah dari IAM task role:
# STORAGE_S3_ACCESS_KEY_ID=
# STORAGE_S3_SECRET_ACCESS_KEY=

# ───────────────────── Email (SES atau SMTP) ─────────────────────
EMAIL_DRIVER=smtp
EMAIL_FROM_ADDRESS=no-reply@bades.id
EMAIL_FROM_NAME=Bades
EMAIL_SMTP_HOST=email-smtp.ap-southeast-1.amazonaws.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=REPLACE_WITH_SES_SMTP_USER
EMAIL_SMTP_PASSWORD=REPLACE_WITH_SES_SMTP_PASSWORD
IS_EMAIL_VERIFICATION_REQUIRED=true

# ───────────────────── AI (single-model, OpenRouter) ─────────────────────
# Hanya satu provider yang aktif user-facing. Lihat .claude/rules/ai-single-model.md
OPENROUTER_API_KEY=sk-or-v1-REPLACE_WITH_PRODUCTION_KEY

# ───────────────────── Monitoring ─────────────────────
EXCEPTION_HANDLER_DRIVER=sentry
SENTRY_DSN=https://REPLACE@sentry.io/REPLACE
SENTRY_FRONT_DSN=https://REPLACE@sentry.io/REPLACE
SENTRY_ENVIRONMENT=production
LOGGER_DRIVER=CONSOLE
LOG_LEVELS=error,warn
APPLICATION_LOG_DRIVER=CONSOLE

# ───────────────────── Rate limiting & security ─────────────────────
API_RATE_LIMITING_TTL=60
API_RATE_LIMITING_LIMIT=120
MUTATION_MAXIMUM_AFFECTED_RECORDS=100
HTTP_TOOL_SAFE_MODE_ENABLED=true

# ───────────────────── Migration control ─────────────────────
# Biarkan migration berjalan otomatis saat container boot (default).
# DISABLE_DB_MIGRATIONS=false
# DISABLE_CRON_JOBS_REGISTRATION=false
