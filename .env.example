# ====================================================================
# Bades — env override OPS-only
# ====================================================================
# Variable di file ini DIATUR OPERATOR DEPLOY (tim Bades).
# Operator desa TIDAK perlu menyentuh file ini — mereka hanya pakai
# antarmuka web Bades yang dilayani dari image GHCR.
#
# Bades adalah produk SaaS managed: satu instance melayani banyak
# workspace desa. Multi-tenant aktif by default, signup workspace baru
# terbuka untuk publik (tidak dibatasi server admin).
# ====================================================================

TAG=latest

# --------------------------------------------------------------------
# Image GHCR
# --------------------------------------------------------------------
# Default mengarah ke ghcr.io/nonomnonom/bades. Override hanya jika
# Anda menjalankan fork yang push image ke registry lain.
#BADES_IMAGE=ghcr.io/<owner>/bades

# --------------------------------------------------------------------
# Mode SaaS (multi-tenant managed)
# --------------------------------------------------------------------
# WAJIB true untuk deployment Bades produksi — engine mendukung banyak
# workspace dalam satu instance. Jangan diubah ke false kecuali sedang
# debug single-tenant.
IS_MULTIWORKSPACE_ENABLED=true

# Workspace bisa dibuat oleh siapa saja yang mendaftar (signup publik).
# Set ke true HANYA jika ingin signup workspace dibatasi ke akun yang
# sudah ditandai `canAccessFullAdminPanel` di DB (mode kios internal).
IS_WORKSPACE_CREATION_LIMITED_TO_SERVER_ADMINS=false

# --------------------------------------------------------------------
# URL & port
# --------------------------------------------------------------------
SERVER_URL=http://localhost:3000

# Override port server di host. Internal selalu 3000.
#SERVER_PORT=3000

# --------------------------------------------------------------------
# Database & cache (didefault ke service Docker Compose)
# --------------------------------------------------------------------
#PG_DATABASE_USER=postgres
#PG_DATABASE_PASSWORD=replace_me_with_a_strong_password
#PG_DATABASE_HOST=db
#PG_DATABASE_PORT=5432
#REDIS_PASSWORD=replace_me_with_a_strong_password
#REDIS_URL=redis://:password@redis:6379

# --------------------------------------------------------------------
# Secret keys (wajib di-generate sekali, jangan dishare)
# --------------------------------------------------------------------
# Generate dengan: openssl rand -base64 32
#ENCRYPTION_KEY=replace_me
#APP_SECRET=replace_me
# Rotation: set FALLBACK_ENCRYPTION_KEY ke nilai lama saat rotate
#FALLBACK_ENCRYPTION_KEY=

# --------------------------------------------------------------------
# Storage (lampiran, foto, file)
# --------------------------------------------------------------------
# local = simpan ke volume Docker. Pakai s3 untuk produksi skala.
STORAGE_TYPE=local

# Aktifkan blok ini saat STORAGE_TYPE=s3
#STORAGE_S3_REGION=ap-southeast-1
#STORAGE_S3_NAME=my-bades-bucket
#STORAGE_S3_ENDPOINT=
#STORAGE_S3_ACCESS_KEY_ID=
#STORAGE_S3_SECRET_ACCESS_KEY=

# --------------------------------------------------------------------
# AI Bades (model tunggal user-facing)
# --------------------------------------------------------------------
# API key OpenRouter; provider model di belakang layar dipilih operator.
#OPENROUTER_API_KEY=sk-or-v1-...

# Override pilihan model default. Default sudah di-bake ke image.
#AI_MODEL_PREFERENCES={"disabledModels":[],"recommendedModels":["openrouter/deepseek/deepseek-v4-flash"],"defaultFastModels":["openrouter/deepseek/deepseek-v4-flash"],"defaultSmartModels":["openrouter/deepseek/deepseek-v4-flash"]}
